{
  "manifest_version": 3,
  "name": "Firefox Tabs AutoPinner",
  "version": "1.0",
  "description": "Automatically opens and pins Firefox tabs for given URLs.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open and pin Firefox tabs",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "applications": {
    "gecko": {
      "id": "05424bc1-235a-46ea-9f85-9af4bbe62e23",
      "strict_min_version": "109.0"
    }
  }
}
